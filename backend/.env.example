FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too
# Prefer DATABASE_URL on Railway. If it is set, the MYSQL_* values below are ignored.
DATABASE_URL=
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DB=incubator_db
CORS_ORIGINS=http://localhost:5173
AUTO_INIT_DB=1
SEED_ADMIN_ON_STARTUP=0
